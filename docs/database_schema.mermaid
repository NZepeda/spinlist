erDiagram
    users ||--o{ reviews : writes
    users ||--o{ favorites : curates
    users ||--o{ follows : follows
    users ||--o{ follows : "followed by"
    
    artists ||--o{ release_groups : creates
    artists ||--o{ mappings : "mapped to"
    
    release_groups ||--o{ albums : contains
    release_groups ||--o{ reviews : "is reviewed"
    release_groups ||--o{ favorites : "is favorited"
    release_groups ||--o{ mappings : "mapped to"

    users {
        uuid id PK
        string username UK
        timestamp created_at
        string status "active, pending (default)"
    }

    artists {
        uuid id PK
        string name
        text_array images
        string slug UK "URL-friendly identifier, e.g. 'the-beatles'"
    
    }

    release_groups {
        uuid id PK
        uuid artist_id FK
        string title
        enum type "album, ep, single"
        int original_release_year
        string mb_group_id UK
        string slug UK "URL-friendly identifier, e.g. 'the-beatles-abbey-road'"
    }

    albums {
        uuid id PK
        uuid release_group_id FK
        string title "e.g. Deluxe Edition"
        text_array images
        jsonb tracklist
    }

    mappings {
        uuid id PK
        uuid artist_id FK "Null unless mapping an artist"
        uuid release_group_id FK "Null unless mapping a release group"
        string provider_name "e.g. spotify, apple_music"
        string provider_id "Unique with provider_name"
        string upc "Null for artists"
    }

    reviews {
        uuid id PK
        uuid user_id FK
        uuid release_group_id FK
        decimal rating "0.5 - 5.0"
        string favorite_track "Provider track ID"
        text body
        timestamp created_at "Used for chronological feed ordering"
        timestamp updated_at
    }

    favorites {
        uuid id PK
        uuid user_id FK
        uuid release_group_id FK
        int position "1-10, unique per user"
        timestamp created_at
    }

    follows {
        uuid follower_id FK
        uuid followed_id FK "Composite PK with follower_id, self-follow disallowed"
        timestamp created_at
    }

    %% mappings constraints:
    %% - exactly one of artist_id or release_group_id must be set
    %% - UNIQUE(provider_name, provider_id)

    %% reviews constraints:
    %% - multiple reviews per (user_id, release_group_id) are allowed
    %% - chronology uses created_at

    %% favorites constraints: 
    %% - UNIQUE(user_id, position)
    %% - UNIQUE(user_id, release_group_id)
